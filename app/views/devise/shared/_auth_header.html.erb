<div class="auth-header">
  <a href="<%= root_path %>" class="auth-logo" aria-label="Go to FestNoz home">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path>
    </svg>
  </a>

  <div>
    <h1 class="auth-title"><%= title %></h1>
    <% if local_assigns[:subtitle].present? %>
      <p class="auth-subtitle"><%= subtitle %></p>
    <% end %>
  </div>
</div>
