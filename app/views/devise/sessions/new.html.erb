<div class="auth-shell">
  <div class="auth-stack">
    <%= render "devise/shared/auth_header", title: "Welcome back", subtitle: "Sign in to your FestNoz account" %>

    <% if flash[:alert] %>
      <div class="auth-flash auth-flash-error"><%= flash[:alert] %></div>
    <% end %>
    <% if flash[:notice] %>
      <div class="auth-flash auth-flash-success"><%= flash[:notice] %></div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-stack" }) do |f| %>
      <div class="auth-panel">
        <div class="auth-field">
          <%= f.label :email, class: "auth-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "auth-input" %>
        </div>

        <div class="auth-field">
          <%= f.label :password, class: "auth-label" %>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "Enter your password", class: "auth-input" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="auth-checkbox-row">
            <%= f.check_box :remember_me, class: "auth-checkbox" %>
            <%= f.label :remember_me, class: "auth-checkbox-label" %>
          </div>
        <% end %>
      </div>

      <%= f.submit "Sign in", class: "auth-button auth-button-primary" %>
    <% end %>

    <div class="auth-divider"><span>Or continue with</span></div>

    <a href="<%= omniauth_authorize_path(resource_name, :spotify) %>" class="auth-button auth-button-outline">
      Continue with Spotify
    </a>

    <div class="auth-cta">
      Don't have an account?
      <%= link_to "Create one", new_registration_path(resource_name) %>
    </div>

    <%= render "devise/shared/links", show_providers: false %>
  </div>
</div>
