<div class="auth-shell">
  <div class="auth-stack">
    <%= render "devise/shared/auth_header", title: "Resend unlock link", subtitle: "Recover access to your account" %>

    <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post, class: "auth-stack" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="auth-panel">
        <div class="auth-field">
          <%= f.label :email, class: "auth-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", class: "auth-input" %>
        </div>
      </div>

      <%= f.submit "Resend unlock instructions", class: "auth-button auth-button-primary" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
