<div class="auth-shell">
  <div class="auth-stack">
    <%= render "devise/shared/auth_header", title: "Create your account", subtitle: "Join FestNoz and never miss a concert" %>

    <% if flash[:alert] %>
      <div class="auth-flash auth-flash-error"><%= flash[:alert] %></div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-stack" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="auth-panel">
        <div class="auth-field">
          <%= f.label :username, class: "auth-label" %>
          <%= f.text_field :username, autofocus: true, placeholder: "Choose a username", class: "auth-input" %>
        </div>

        <div class="auth-field">
          <%= f.label :email, class: "auth-label" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com", class: "auth-input" %>
        </div>

        <div class="auth-field">
          <%= f.label :password, class: "auth-label" %>
          <% if @minimum_password_length %>
            <p class="auth-hint"><%= @minimum_password_length %> characters minimum</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "Create a password", class: "auth-input" %>
        </div>

        <div class="auth-field">
          <%= f.label :password_confirmation, class: "auth-label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm your password", class: "auth-input" %>
        </div>
      </div>

      <%= f.submit "Create account", class: "auth-button auth-button-primary" %>
    <% end %>

    <div class="auth-divider"><span>Or continue with</span></div>

    <a href="<%= omniauth_authorize_path(resource_name, :spotify) %>" class="auth-button auth-button-outline">
      Continue with Spotify
    </a>

    <div class="auth-cta">
      Already have an account?
      <%= link_to "Sign in", new_session_path(resource_name) %>
    </div>

    <%= render "devise/shared/links", show_providers: false %>
  </div>
</div>
